<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jcrawley.gmail-mcp-http</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>exec node "$(npm root -g)/@shinzolabs/gmail-mcp/dist/index.js"</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PORT</key>
        <string>8765</string>
        <key>GMAIL_HTTP_ONLY</key>
        <string>1</string>
        <key>MCP_CONFIG_DIR</key>
        <string>/Users/jcrawley/.gmail-mcp</string>
        <key>TELEMETRY_ENABLED</key>
        <string>false</string>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>/Users/jcrawley/.claude/logs/gmail-mcp-http.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jcrawley/.claude/logs/gmail-mcp-http.log</string>
</dict>
</plist>
